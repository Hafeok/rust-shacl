@prefix dash: <http://datashapes.org/dash#> .
@prefix ex: <http://example.com/ns#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Organism
  rdf:type rdfs:Class ;
.

ex:Animal
  rdf:type rdfs:Class ;
  rdfs:subClassOf ex:Organism ;
.

ex:Mammal
  rdf:type rdfs:Class ;
  rdfs:subClassOf ex:Animal ;
.

ex:Dog
  rdf:type rdfs:Class ;
  rdfs:subClassOf ex:Mammal ;
.

ex:Plant
  rdf:type rdfs:Class ;
  rdfs:subClassOf ex:Organism ;
.

ex:Car
  rdf:type rdfs:Class ;
.

ex:Zoo
  ex:holds ex:Animal ;
  ex:holds ex:Mammal ;
  ex:holds ex:Dog ;
  ex:holds ex:Plant ;
  ex:holds ex:Car ;
.

ex:TestShape
  a sh:NodeShape ;
  sh:targetNode ex:Zoo ;
  sh:property ex:TestShape-holds ;
.

ex:TestShape-holds
  a sh:PropertyShape ;
  sh:path ex:holds ;
  sh:rootClass ex:Animal ;
.

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <rootClass-001>
    ) ;
.

<rootClass-001>
  rdf:type sht:Validate ;
  rdfs:label "Test of sh:rootClass at property shape 001" ;
  mf:action [
      sht:dataGraph <> ;
      sht:shapesGraph <> ;
    ] ;
  mf:result [
      rdf:type sh:ValidationReport ;
      sh:conforms "false"^^xsd:boolean ;
      sh:result [
          rdf:type sh:ValidationResult ;
          sh:focusNode ex:Zoo ;
          sh:resultPath ex:holds ;
          sh:value ex:Plant ;
          sh:resultSeverity sh:Violation ;
          sh:sourceConstraintComponent sh:RootClassConstraintComponent ;
          sh:sourceShape ex:TestShape-holds ;
        ] ;
      sh:result [
          a sh:ValidationResult ;
          sh:focusNode ex:Zoo ;
          sh:resultPath ex:holds ;
          sh:value ex:Car ;
          sh:resultSeverity sh:Violation ;
          sh:sourceConstraintComponent sh:RootClassConstraintComponent ;
          sh:sourceShape ex:TestShape-holds ;
        ] ;
    ] ;
  mf:status sht:approved ;
.
